# Chaves do projeto Supabase.
# Copie este arquivo para .env e preencha com os valores reais.
# Onde encontrar: painel do Supabase > Project Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Chave pública VAPID para Web Push (gerada com: npx web-push generate-vapid-keys).
# A chave PRIVADA não vai aqui — é secret da Edge Function (supabase secrets set).
VITE_VAPID_PUBLIC_KEY=
